{
	"module": "wa.ts",
	"type": "module",
	"exports": "./wa.ts",
	"engines": {
		"node": ">=25"
	},
	"scripts": {
		"presetup": "npm install -g pm2 prisma",
		"setup": "npm run presetup && npm install && npm run setup:py",
		"setup:full": "npm run prisma:push && npm run setup",
		"setup:py": "python3 -m venv conf/gen/python && conf/gen/python/bin/pip install rembg onnxruntime yt-dlp[default,curl-cffi]",
		"update": "npm outdated; git pull origin master; npm run presetup; npm update --save; deno upgrade; bun upgrade; npm run update:py; npm run postinstall",
		"update:py": "conf/gen/python/bin/pip install -U rembg onnxruntime yt-dlp[default,curl-cffi]",
		"postinstall": "rm package-lock.json & npm run prisma:gen",
		"start": "npx pm2 start conf/ecosystem.config.cjs --attach",
		"restart": "npx pm2 restart wa --attach",
		"stop": "npx pm2 delete wa",
		"prisma:gen": "npx prisma generate --schema=conf/gen/schema.prisma",
		"prisma:push": "npx prisma db push --schema=conf/gen/schema.prisma",
		"prisma:pull": "npx prisma db pull --schema=conf/gen/schema.prisma",
		"reset": "rm -r conf/gen/auth/* conf/gen/cache/* conf/gen/temp/*",
		"reset:cache": "rm -r conf/cache/*",
		"fmt": "deno fmt ./ --config=conf/deno.jsonc",
		"dev": "npm run stop; DEV=1 npx pm2 start conf/ecosystem.config.cjs --attach",
		"translate": "npx @parvineyvazov/json-translator locale/pt.json -m google -f pt -t en es fr de"
	},
	"dependencies": {
		"@google/genai": "^2.11.0",
		"@prisma/client": "^7.8.0",
		"baileys": "github:whiskeysockets/Baileys",
		"chalk": "^5.6.2",
		"google-translate-api-x": "^10.7.3",
		"humanize-duration": "^3.34.0",
		"i18next": "^26.3.6",
		"i18next-fs-backend": "^2.6.6",
		"luxon": "^3.7.2",
		"node-cron": "^4.6.0",
		"node-webpmux": "^3.2.1",
		"pino": "^10.3.1",
		"qrcode": "^1.5.4",
		"wa-sticker-formatter": "^4.4.4"
	},
	"devDependencies": {
		"@prisma/adapter-pg": "^7.8.0",
		"@types/humanize-duration": "^3.27.4",
		"@types/luxon": "^3.7.2",
		"@types/node": "^25.9.5",
		"@types/node-cron": "^3.0.11",
		"@types/qrcode": "^1.5.6",
		"pino-pretty": "^13.1.3",
		"prisma": "^7.8.0"
	}
}
