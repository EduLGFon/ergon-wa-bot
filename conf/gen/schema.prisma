generator client {
  provider = "prisma-client"
  output = "./prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id       Int     @id @default(autoincrement())
  lid      String  @unique @db.VarChar()
  name     String? @db.VarChar()
  memories String? @db.VarChar()
  lang     String? @db.VarChar()
  prefix   String? @db.VarChar()
  cmds     Int?
}

model alarms {
  id     Int    @id @default(autoincrement())
  author Int
  chat   String @db.VarChar()
  msg    String @db.VarChar()
  time   String @db.VarChar()
  status Int    @default(0)
}

model msgs {
  author Int
  group  String @db.VarChar()
  count  Int    @default(1)

  @@id([author, group])
}


model authStorage {
  key  String @id
  data Json

}

model authCreds {
  session   String @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model authKey {
  session   String
  category  String
  key       String
  data      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([session, category, key])
  @@index([session, category])
}
