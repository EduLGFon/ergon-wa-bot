{
	"fmt": { // DENO Formatter settings
		"indentWidth": 4,
		"singleQuote": true,
		"useTabs": true,
		"semiColons": false,
		"lineWidth": 100,
		"exclude": [
			"conf/gen/python",
			"conf/gen/auth",
			"conf/gen/temp",
			"conf/gen/prisma"
		]
	},
	"lint": { // DENO Lint rules
		"rules": {
			"exclude": [
				"no-explicit-any"
			] // does not throws at any any
		}
	},
	"imports": {},
	"unstable": [] // DENO unstable features
}